# Vite loads .env files in this order (later overrides earlier):
#   .env                    always
#   .env.[mode]             matching mode only (e.g. .env.development for `npm run dev`)
#   .env.local              always (gitignored — personal overrides)
#   .env.[mode].local       matching mode only, gitignored
#
# Ship-side defaults live in code; the .env.development file in this
# repo points local dev at ci.kbase.us. Production builds fall through
# to the canonical kbase.us defaults.

# Origin of the kbase auth service. Production: kbase.us (canonical;
# pointing at narrative.kbase.us breaks the in-process cookie). Local
# dev (.env.development): ci.kbase.us. Production Docker builds MUST
# pass this as `--build-arg VITE_AUTH_ORIGIN=...` so the Vite bundle
# AND the nginx CSP (connect-src, form-action) agree.
VITE_AUTH_ORIGIN=https://kbase.us

# Domain attribute for the kbase_session cookie. `.kbase.us` makes it
# readable by every kbase.us subdomain (cross-subdomain SSO). Leave
# unset locally so the cookie scopes to the current host. Empty string
# also works to omit the Domain attribute explicitly.
# VITE_COOKIE_DOMAIN=.kbase.us

# Comma-separated host allow-list for the Vite dev server. A leading
# dot is Vite's subdomain wildcard (`.example.com` allows any
# subdomain). Personal dev hostnames go here, not into source.
# VITE_DEV_ALLOWED_HOSTS=.example.com,localhost
